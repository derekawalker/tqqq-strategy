# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.

# Schwab Developer App credentials
# Register at https://developer.schwab.com
SCHWAB_CLIENT_ID=your_client_id_here
SCHWAB_CLIENT_SECRET=your_client_secret_here

# Must match exactly what's registered in your Schwab app
# Schwab requires HTTPS and doesn't allow "localhost" — use 127.0.0.1
SCHWAB_REDIRECT_URI=https://127.0.0.1:3000/api/auth/callback

# Use localhost (not 127.0.0.1) for the app so normal dev browsing works
NEXT_PUBLIC_APP_URL=https://localhost:3000

# Supabase (token + settings storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# TastyTrade credentials (live account)
TASTYTRADE_USERNAME=your_tastytrade_username
TASTYTRADE_PASSWORD=your_tastytrade_password
# Comma-separated list of account numbers to include (leave unset for all)
TASTYTRADE_ACCOUNTS=

# TastyTrade sandbox (cert) — for testing order placement without real trades
# 1. Create an OAuth2 app at https://developer.tastytrade.com
# 2. Under your app, click Manage → Create Grant to generate a refresh token
# Toggle sandbox per-session from the Working Orders page UI.
TASTYTRADE_SANDBOX=false
TASTYTRADE_SANDBOX_CLIENT_ID=your_sandbox_client_id
TASTYTRADE_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret
TASTYTRADE_SANDBOX_REFRESH_TOKEN=your_sandbox_refresh_token
TASTYTRADE_SANDBOX_ACCOUNT=your_sandbox_account_number

# App authentication — password for the login page
APP_PASSWORD=choose_a_strong_password

# Session secret — generate with: openssl rand -hex 32
APP_SESSION_SECRET=generate_a_random_64_char_hex_string
